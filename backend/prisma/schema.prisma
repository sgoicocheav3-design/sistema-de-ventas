// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Usuario ──────────────────────────────────────────────────────────────────
model Usuario {
  id             Int       @id @default(autoincrement())
  nombre         String    @db.VarChar(255)
  email          String    @unique @db.VarChar(255)
  passwordHash   String    @db.Text
  rol            String    @db.VarChar(50)  // ADMIN, GERENTE, VENDEDOR, ALMACENERO
  activo         Boolean   @default(true)
  creadoEn       DateTime  @default(now())
  
  logAccesos        LogAcceso[]
  ventas            Venta[]
  entradasMercaderia EntradaMercaderia[]
  bajas             BajaInventario[]
  solicitudes       SolicitudReposicion[]
  
  @@map("usuarios")
}

// ─── LogAcceso ────────────────────────────────────────────────────────────────
model LogAcceso {
  id             Int       @id @default(autoincrement())
  usuarioId      Int
  rol            String    @db.VarChar(50)
  timestamp      DateTime  @default(now())
  
  usuario        Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  
  @@index([usuarioId])
  @@map("log_accesos")
}

// ─── Categoría ────────────────────────────────────────────────────────────────
model Categoria {
  id             Int       @id @default(autoincrement())
  nombre         String    @unique @db.VarChar(255)
  
  productos      Producto[]
  
  @@map("categorias")
}

// ─── Producto ─────────────────────────────────────────────────────────────────
model Producto {
  id             Int       @id @default(autoincrement())
  nombre         String    @db.VarChar(255)
  marca          String    @db.VarChar(255)
  precio         Decimal   @db.Decimal(10, 2)
  stock          Int       @default(0)
  fechaVencimiento DateTime?
  activo         Boolean   @default(true)
  categoriaId    Int
  creadoEn       DateTime  @default(now())
  
  categoria      Categoria @relation(fields: [categoriaId], references: [id], onDelete: Restrict)
  detallesVenta  DetalleVenta[]
  entradasMercaderia EntradaMercaderia[]
  bajas          BajaInventario[]
  solicitudes    SolicitudReposicion[]
  
  @@unique([nombre, activo])
  @@index([categoriaId, activo])
  @@index([nombre, marca])
  @@map("productos")
}

// ─── Proveedor ────────────────────────────────────────────────────────────────
model Proveedor {
  id             Int       @id @default(autoincrement())
  nombre         String    @db.VarChar(255)
  ruc            String    @unique @db.VarChar(11)
  contacto       String    @db.VarChar(255)
  activo         Boolean   @default(true)
  creadoEn       DateTime  @default(now())
  
  entradasMercaderia EntradaMercaderia[]
  
  @@map("proveedores")
}

// ─── ConfigSistema ────────────────────────────────────────────────────────────
model ConfigSistema {
  clave          String    @id @db.VarChar(255)
  valor          String    @db.Text
  
  @@map("config_sistema")
}

// ─── Venta ────────────────────────────────────────────────────────────────────
model Venta {
  id             Int       @id @default(autoincrement())
  numero         String    @unique @db.VarChar(20)
  usuarioId      Int
  subtotal       Decimal   @db.Decimal(12, 2)
  igv            Decimal   @db.Decimal(12, 2)
  total          Decimal   @db.Decimal(12, 2)
  metodoPago     String    @db.VarChar(50)
  montoRecibido  Decimal   @default(0) @db.Decimal(12, 2)
  vuelto         Decimal   @default(0) @db.Decimal(12, 2)
  estado         String    @default("COMPLETADA") @db.VarChar(50)
  creadoEn       DateTime  @default(now())
  
  detalles       DetalleVenta[]
  usuario        Usuario    @relation(fields: [usuarioId], references: [id])
  
  @@index([usuarioId, creadoEn])
  @@map("ventas")
}

// ─── DetalleVenta ────────────────────────────────────────────────────────────
model DetalleVenta {
  id             Int       @id @default(autoincrement())
  ventaId        Int
  productoId     Int
  cantidad       Int
  precioUnitario Decimal   @db.Decimal(10, 2)
  subtotal       Decimal   @db.Decimal(12, 2)
  
  venta          Venta     @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  producto       Producto  @relation(fields: [productoId], references: [id], onDelete: Restrict)
  
  @@index([ventaId])
  @@index([productoId])
  @@map("detalles_venta")
}

// ─── EntradaMercaderia ────────────────────────────────────────────────────────
model EntradaMercaderia {
  id             Int       @id @default(autoincrement())
  productoId     Int
  proveedorId    Int
  cantidad       Int
  precioUnitario Decimal   @db.Decimal(10, 2)
  usuarioId      Int
  creadoEn       DateTime  @default(now())
  
  producto       Producto  @relation(fields: [productoId], references: [id], onDelete: Restrict)
  proveedor      Proveedor @relation(fields: [proveedorId], references: [id], onDelete: Restrict)
  usuario        Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Restrict)
  
  @@index([productoId, creadoEn])
  @@index([proveedorId])
  @@map("entradas_mercaderia")
}

// ─── BajaInventario ──────────────────────────────────────────────────────────
model BajaInventario {
  id             Int       @id @default(autoincrement())
  productoId     Int
  cantidad       Int
  motivo         String    @db.VarChar(255)
  usuarioId      Int
  creadoEn       DateTime  @default(now())
  
  producto       Producto  @relation(fields: [productoId], references: [id], onDelete: Restrict)
  usuario        Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Restrict)
  
  @@index([productoId, creadoEn])
  @@map("bajas_inventario")
}

// ─── SolicitudReposicion ──────────────────────────────────────────────────────
model SolicitudReposicion {
  id             Int       @id @default(autoincrement())
  productoId     Int
  cantidadActual Int
  cantidadSolicitada Int
  estado         String    @default("PENDIENTE") @db.VarChar(50)
  usuarioId      Int
  creadoEn       DateTime  @default(now())
  
  producto       Producto  @relation(fields: [productoId], references: [id], onDelete: Restrict)
  usuario        Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Restrict)
  
  @@index([estado, creadoEn])
  @@map("solicitudes_reposicion")
}
