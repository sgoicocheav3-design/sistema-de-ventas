// backend/src/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Rol {
  ADMIN
  VENDEDOR
  ALMACENERO
  GERENTE
}

enum MetodoPago {
  EFECTIVO
  YAPE
  PLIN
}

enum EstadoSolicitud {
  PENDIENTE
  APROBADA
  RECHAZADA
  COMPLETADA
}

// ─────────────────────────────────────────────
// MODELOS
// ─────────────────────────────────────────────

model Usuario {
  id           Int       @id @default(autoincrement())
  nombre       String
  email        String    @unique
  passwordHash String
  rol          Rol
  activo       Boolean   @default(true)
  resetCode    String?
  resetExpiry  DateTime?
  creadoEn     DateTime  @default(now())

  ventas             Venta[]
  entradasMercaderia EntradaMercaderia[]
  bajas              BajaInventario[]
  solicitudes        SolicitudReposicion[] @relation("Almacenero")
  logs               LogAcceso[]
}

model Categoria {
  id        Int        @id @default(autoincrement())
  nombre    String     @unique
  productos Producto[]
}

model Producto {
  id               Int       @id @default(autoincrement())
  nombre           String
  marca            String
  categoriaId      Int
  precio           Decimal   @db.Decimal(10, 2)
  stock            Int       @default(0)
  fechaVencimiento DateTime?
  activo           Boolean   @default(true)

  categoria          Categoria           @relation(fields: [categoriaId], references: [id])
  detallesVenta      DetalleVenta[]
  entradasMercaderia EntradaMercaderia[]
  bajas              BajaInventario[]
  solicitudes        SolicitudReposicion[]

  @@index([nombre, marca])
  @@index([categoriaId, activo])
}

model Proveedor {
  id       Int     @id @default(autoincrement())
  nombre   String
  ruc      String  @unique
  contacto String
  activo   Boolean @default(true)

  entradasMercaderia EntradaMercaderia[]
  solicitudes        SolicitudReposicion[]
}

model Cliente {
  id     Int     @id @default(autoincrement())
  dni    String  @unique
  nombre String
  email  String?

  ventas Venta[]
}

model Venta {
  id            Int        @id @default(autoincrement())
  vendedorId    Int
  clienteId     Int?
  metodoPago    MetodoPago
  montoTotal    Decimal    @db.Decimal(10, 2)
  montoRecibido Decimal    @db.Decimal(10, 2)
  igv           Decimal    @db.Decimal(10, 2)
  creadoEn      DateTime   @default(now())

  vendedor Usuario  @relation(fields: [vendedorId], references: [id])
  cliente  Cliente? @relation(fields: [clienteId], references: [id])
  detalles DetalleVenta[]
}

model DetalleVenta {
  id             Int     @id @default(autoincrement())
  ventaId        Int
  productoId     Int
  cantidad       Int
  precioUnitario Decimal @db.Decimal(10, 2)

  venta    Venta    @relation(fields: [ventaId], references: [id])
  producto Producto @relation(fields: [productoId], references: [id])
}

model EntradaMercaderia {
  id          Int      @id @default(autoincrement())
  productoId  Int
  proveedorId Int
  cantidad    Int
  usuarioId   Int
  creadoEn    DateTime @default(now())

  producto  Producto  @relation(fields: [productoId], references: [id])
  proveedor Proveedor @relation(fields: [proveedorId], references: [id])
  usuario   Usuario   @relation(fields: [usuarioId], references: [id])
}

model BajaInventario {
  id         Int      @id @default(autoincrement())
  productoId Int
  cantidad   Int
  motivo     String
  usuarioId  Int
  creadoEn   DateTime @default(now())

  producto Producto @relation(fields: [productoId], references: [id])
  usuario  Usuario  @relation(fields: [usuarioId], references: [id])
}

model SolicitudReposicion {
  id                 Int             @id @default(autoincrement())
  productoId         Int
  proveedorId        Int?
  cantidadSolicitada Int
  estado             EstadoSolicitud @default(PENDIENTE)
  fechaEstimada      DateTime?
  notaRechazo        String?
  almaceneroId       Int
  creadoEn           DateTime        @default(now())

  producto   Producto   @relation(fields: [productoId], references: [id])
  proveedor  Proveedor? @relation(fields: [proveedorId], references: [id])
  almacenero Usuario    @relation("Almacenero", fields: [almaceneroId], references: [id])
}

model LogAcceso {
  id        Int      @id @default(autoincrement())
  usuarioId Int
  rol       Rol
  creadoEn  DateTime @default(now())
  archivado Boolean  @default(false)

  usuario Usuario @relation(fields: [usuarioId], references: [id])
}

model ConfigSistema {
  clave String @id
  valor String
}
