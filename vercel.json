{
  "version": 2,
  "buildCommand": "cd backend && npm install && npm run db:generate && cd ../frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "public": false,
  "env": {
    "DATABASE_URL": "@database_url",
    "JWT_SECRET": "@jwt_secret",
    "JWT_EXPIRES_IN": "@jwt_expires_in",
    "SMTP_HOST": "@smtp_host",
    "SMTP_PORT": "@smtp_port",
    "SMTP_USER": "@smtp_user",
    "SMTP_PASS": "@smtp_pass",
    "PORT": "4000"
  },
  "functions": {
    "backend/server.js": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "http://localhost:4000/api/$1"
    }
  ]
}
