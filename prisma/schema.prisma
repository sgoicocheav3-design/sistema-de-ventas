generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Usuario {
  id             Int       @id @default(autoincrement())
  nombre         String    @db.VarChar(255)
  email          String    @unique @db.VarChar(255)
  passwordHash   String    @db.Text
  rol            String    @db.VarChar(50)
  activo         Boolean   @default(true)
  intentosFallidos Int     @default(0)
  bloqueadoHasta  DateTime?
  resetTokenHash String?   @db.Text
  resetExpiry    DateTime?
  resetUsed      Boolean   @default(false)
  creadoEn       DateTime  @default(now())

  logAccesos        LogAcceso[]
  ventas            Venta[]
  entradasMercaderia EntradaMercaderia[]
  bajas             BajaInventario[]
  solicitudesCreadas SolicitudReposicion[]  @relation("solicitante")
  solicitudesRevisadas SolicitudReposicion[] @relation("revisor")
  notificaciones Notificacion[]
  auditorias     Auditoria[]
  recepciones    RecepcionMercaderia[]

  @@map("usuarios")
}

model LogAcceso {
  id             Int       @id @default(autoincrement())
  usuarioId      Int?
  email          String?   @db.VarChar(255)
  accion         String    @db.VarChar(255)
  ip             String?   @db.VarChar(45)
  userAgent      String?   @db.Text
  creadoEn       DateTime  @default(now())

  usuario        Usuario?  @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  @@index([usuarioId])
  @@index([creadoEn])
  @@map("log_accesos")
}

model Categoria {
  id             Int       @id @default(autoincrement())
  nombre         String    @unique @db.VarChar(255)

  productos      Producto[]

  @@map("categorias")
}

model Producto {
  id             Int       @id @default(autoincrement())
  codigo         String    @unique @db.VarChar(50)
  nombre         String    @db.VarChar(255)
  marca          String?   @db.VarChar(255)
  precio         Decimal   @db.Decimal(10, 2)
  stock          Int       @default(0)
  fechaVencimiento DateTime?
  activo         Boolean   @default(true)
  categoriaId    Int?
  creadoEn       DateTime  @default(now())

  categoria      Categoria? @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  detallesVenta  DetalleVenta[]
  entradasMercaderia EntradaMercaderia[]
  bajas          BajaInventario[]
  solicitudes    SolicitudReposicion[]
  auditorias     Auditoria[]
  recepciones    RecepcionMercaderia[]
  proveedores    ProveedorProducto[]

  @@index([categoriaId, activo])
  @@index([nombre, marca])
  @@map("productos")
}

model Proveedor {
  id             Int       @id @default(autoincrement())
  nombre         String    @db.VarChar(255)
  ruc            String    @unique @db.VarChar(11)
  contacto       String?   @db.VarChar(255)
  email          String?   @db.VarChar(255)
  telefono       String?   @db.VarChar(20)
  activo         Boolean   @default(true)
  creadoEn       DateTime  @default(now())

  entradasMercaderia EntradaMercaderia[]
  solicitudes        SolicitudReposicion[]
  recepciones        RecepcionMercaderia[]
  productos          ProveedorProducto[]

  @@map("proveedores")
}

model ProveedorProducto {
  proveedorId    Int
  productoId     Int

  proveedor      Proveedor @relation(fields: [proveedorId], references: [id], onDelete: Cascade)
  producto       Producto  @relation(fields: [productoId], references: [id], onDelete: Cascade)

  @@id([proveedorId, productoId])
  @@index([productoId])
  @@map("proveedores_productos")
}

model ConfigSistema {
  clave          String    @id @db.VarChar(255)
  valor          String    @db.Text

  @@map("config_sistema")
}

model Cliente {
  id             Int       @id @default(autoincrement())
  dni            String    @unique @db.VarChar(8)
  nombre         String    @db.VarChar(255)
  email          String?   @db.VarChar(255)
  telefono       String?   @db.VarChar(20)
  activo         Boolean   @default(true)
  creadoEn       DateTime  @default(now())

  ventas         Venta[]

  @@index([dni])
  @@map("clientes")
}

model Venta {
  id             Int       @id @default(autoincrement())
  numero         String    @unique @db.VarChar(20)
  usuarioId      Int
  clienteId      Int?
  subtotal       Decimal   @db.Decimal(12, 2)
  igv            Decimal   @db.Decimal(12, 2)
  total          Decimal   @db.Decimal(12, 2)
  metodoPago     String    @db.VarChar(50)
  montoRecibido  Decimal   @default(0) @db.Decimal(12, 2)
  vuelto         Decimal   @default(0) @db.Decimal(12, 2)
  estado         String    @default("COMPLETADA") @db.VarChar(50)
  pagoId         String?   @unique @db.VarChar(100)
  qrData         String?   @db.Text
  creadoEn       DateTime  @default(now())

  detalles       DetalleVenta[]
  usuario        Usuario    @relation(fields: [usuarioId], references: [id])
  cliente        Cliente?   @relation(fields: [clienteId], references: [id])

  @@index([usuarioId, creadoEn])
  @@index([clienteId])
  @@map("ventas")
}

model DetalleVenta {
  id             Int       @id @default(autoincrement())
  ventaId        Int
  productoId     Int
  cantidad       Int
  precioUnitario Decimal   @db.Decimal(10, 2)
  subtotal       Decimal   @db.Decimal(12, 2)

  venta          Venta     @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  producto       Producto  @relation(fields: [productoId], references: [id], onDelete: Restrict)

  @@index([ventaId])
  @@index([productoId])
  @@map("detalles_venta")
}

model EntradaMercaderia {
  id             Int       @id @default(autoincrement())
  productoId     Int
  proveedorId    Int
  cantidad       Int
  usuarioId      Int
  observacion    String?   @db.Text
  creadoEn       DateTime  @default(now())

  producto       Producto  @relation(fields: [productoId], references: [id], onDelete: Restrict)
  proveedor      Proveedor @relation(fields: [proveedorId], references: [id], onDelete: Restrict)
  usuario        Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Restrict)

  @@index([productoId, creadoEn])
  @@index([proveedorId])
  @@map("entradas_mercaderia")
}

model BajaInventario {
  id             Int       @id @default(autoincrement())
  productoId     Int
  cantidad       Int
  motivo         String    @db.VarChar(255)
  usuarioId      Int
  creadoEn       DateTime  @default(now())

  producto       Producto  @relation(fields: [productoId], references: [id], onDelete: Restrict)
  usuario        Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Restrict)

  @@index([productoId, creadoEn])
  @@map("bajas_inventario")
}

model SolicitudReposicion {
  id                 Int        @id @default(autoincrement())
  productoId         Int
  cantidad           Int
  estado             String     @default("PENDIENTE") @db.VarChar(50)
  solicitanteId      Int
  revisorId          Int?
  revisadoEn         DateTime?
  notaRechazo        String?    @db.Text
  proveedorId        Int?
  creadoEn           DateTime   @default(now())

  producto           Producto   @relation(fields: [productoId], references: [id], onDelete: Restrict)
  solicitante        Usuario    @relation("solicitante", fields: [solicitanteId], references: [id], onDelete: Restrict)
  revisor            Usuario?   @relation("revisor", fields: [revisorId], references: [id], onDelete: SetNull)
  proveedor          Proveedor? @relation(fields: [proveedorId], references: [id], onDelete: SetNull)
  recepciones        RecepcionMercaderia[]

  @@index([estado, creadoEn])
  @@map("solicitudes_reposicion")
}

model RecepcionMercaderia {
  id             Int       @id @default(autoincrement())
  solicitudId    Int
  productoId     Int
  proveedorId    Int
  cantidad       Int
  usuarioId      Int
  creadoEn       DateTime  @default(now())

  solicitud      SolicitudReposicion @relation(fields: [solicitudId], references: [id], onDelete: Restrict)
  producto       Producto            @relation(fields: [productoId], references: [id], onDelete: Restrict)
  proveedor      Proveedor           @relation(fields: [proveedorId], references: [id], onDelete: Restrict)
  usuario        Usuario             @relation(fields: [usuarioId], references: [id], onDelete: Restrict)

  @@index([solicitudId])
  @@index([creadoEn])
  @@map("recepciones_mercaderia")
}

model Notificacion {
  id             Int       @id @default(autoincrement())
  usuarioId      Int
  titulo         String    @db.VarChar(255)
  mensaje        String?   @db.Text
  leida          Boolean   @default(false)
  creadoEn       DateTime  @default(now())

  usuario        Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId, leida])
  @@map("notificaciones")
}

model Auditoria {
  id             Int       @id @default(autoincrement())
  usuarioId      Int
  productoId     Int
  accion         String    @db.VarChar(255)
  detalles       String?   @db.Text
  creadoEn       DateTime  @default(now())

  usuario        Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Restrict)
  producto       Producto  @relation(fields: [productoId], references: [id], onDelete: Restrict)

  @@index([productoId, creadoEn])
  @@index([usuarioId])
  @@map("auditoria")
}
